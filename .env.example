# ─── Flask Backend ────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=./backend/credentials/google-service-account.json

# ─── AI ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-...

# ─── Telegram ─────────────────────────────────────────────────────────────────
CENTRAL_BOT_TOKEN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://dashboard.staybot.ai

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATELIMIT_DEFAULT=100/minute
RATELIMIT_AUTH=5/minute

# ─── Dashboard (Vite) ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000
VITE_APP_NAME=StayBot AI

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=https://your-username/webhook-test/telegram-central
N8N_BASE_URL=https://n8n.staybot.ai
